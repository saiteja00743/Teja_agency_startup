# ── App ──────────────────────────────────────────────────────────
APP_NAME=Teja Labs
APP_ENV=development
SECRET_KEY=change-me-to-a-random-64-char-hex-string
ADMIN_PASSWORD=change-me-in-production

# ── Database ─────────────────────────────────────────────────────
# SQLite (default, great for dev and small production):
DATABASE_URL=sqlite:///./teja_agency.db

# PostgreSQL (recommended for production, e.g. Railway/Render):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Email Notifications (optional) ───────────────────────────────
# Leave blank to skip email — leads are still saved to DB.
# Gmail example: use an App Password, not your account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
NOTIFICATION_EMAIL=leads@yourdomain.com

# ── CORS ─────────────────────────────────────────────────────────
# Use * for dev; for prod, set your actual domain(s):
# ALLOWED_ORIGINS=https://tejlabs.com,https://www.tejlabs.com
ALLOWED_ORIGINS=*
